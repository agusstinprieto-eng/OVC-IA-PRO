# ============================================================
#  OCV TORREÓN — Ecosistema Digital
#  Copia este archivo como .env.local y rellena tus valores
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard/project/TU_PROJECT_ID/settings/api
VITE_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...tu_anon_key_aqui

# Solo en servidor (Vercel env vars / API routes) — NUNCA en el frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...tu_service_role_key_aqui
SUPABASE_URL=https://TU_PROJECT_ID.supabase.co

# ── Stripe ───────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_...          # o pk_live_... en producción
STRIPE_SECRET_KEY=sk_test_...               # solo servidor
STRIPE_WEBHOOK_SECRET=whsec_...             # Stripe CLI: stripe listen --print-secret

# ── MercadoPago ──────────────────────────────────────────────
# Dashboard: https://www.mercadopago.com.mx/developers/panel/app
VITE_MP_PUBLIC_KEY=APP_USR-...              # Public Key de tu aplicación MP
MP_ACCESS_TOKEN=APP_USR-...                 # Access Token (solo servidor)

# ── App ──────────────────────────────────────────────────────
VITE_APP_NAME="OCV Torreón"
VITE_APP_URL=https://ocv-ia-pro.vercel.app  # o tu dominio custom

# ── Auth callbacks (configurar en Supabase Dashboard) ────────
# Authentication > URL Configuration > Redirect URLs:
#   https://ocv-ia-pro.vercel.app/auth/callback
#   http://localhost:5173/auth/callback
